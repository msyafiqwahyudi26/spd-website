# ──────────────────────────────────────────────────────────────────
# SPD Frontend — production env template
# Used by Vite at build time. Variables MUST start with VITE_.
# ──────────────────────────────────────────────────────────────────

# Absolute URL (with /api) that the deployed browser will hit.
# Same-origin API (reverse-proxied under /api):
VITE_API_URL=/api
# Separate API subdomain:
# VITE_API_URL=https://api.spdindonesia.org/api
