# ──────────────────────────────────────────────────────────────────
# SPD Backend — env template
# Copy to .env and fill in. Never commit real .env values.
# ──────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────────
# Local Postgres on the same VPS:
DATABASE_URL=postgresql://spd_user:CHANGE_ME@localhost:5432/spd_production?schema=public
# Managed Postgres (e.g. RDS, Supabase, Neon):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public&sslmode=require

# ── Auth ──────────────────────────────────────────────────────────
# REQUIRED. Minimum 32 characters. Server refuses to start otherwise.
# Generate with:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_REPLACE_WITH_32_PLUS_CHAR_RANDOM_STRING

# ── Frontend origin (CORS allowlist) ──────────────────────────────
# In production this is the ONLY allowed origin. Must match the scheme
# and host (no trailing slash) the browser sends.
FRONTEND_URL=https://spdindonesia.org

# ── Proxy awareness ───────────────────────────────────────────────
# Number of reverse proxies in front of this app. Wrong values let
# attackers spoof X-Forwarded-For and bypass rate limits.
#   0 — direct (no proxy)
#   1 — behind one proxy (Nginx only)            ← typical single-VPS setup
#   2 — behind two proxies (Cloudflare + Nginx)
TRUST_PROXY=1

# ── Email (SMTP) ──────────────────────────────────────────────────
# Leave all EMAIL_* blank to disable email entirely. Contact form and
# admin replies will be skipped gracefully with a startup warning.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=no-reply@spdindonesia.org
EMAIL_PASS=CHANGE_ME
EMAIL_FROM=SPD Indonesia <no-reply@spdindonesia.org>
EMAIL_TO=admin@spdindonesia.org
