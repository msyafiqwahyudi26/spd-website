generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  password   String
  name       String
  role       String   @default("admin")
  // Auth provider: "local" for email+password, "google" for Google Workspace.
  // providerId stores the external identifier (e.g. Google sub) so a single
  // user can be uniquely identified by (provider, providerId).
  provider   String   @default("local")
  providerId String?
  createdAt  DateTime @default(now())

  @@unique([provider, providerId], name: "provider_providerId")
}

model Publication {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  category    String
  // Content type determines how the publication renders on the public site.
  //   "article"  — default, narrative/opinion text
  //   "research" — structured research with emphasis on reading time + author
  //   "book"     — downloadable PDF featured prominently
  contentType String   @default("article")
  description String   @default("")
  author      String   @default("")
  readTime    String   @default("")
  date        String   @default("")
  fullContent String   @default("[]")
  image       String?
  // PDF attachment for research reports / books. Stored as URL; upload via
  // the Media manager (PDFs are accepted in the upload filter).
  pdfUrl      String?
  gallery     String   @default("[]")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
}

// Program is a long-term institutional initiative, NOT a dated event.
// Events have a schedule (startsAt); Programs don't. The split is
// conceptual: visitors browsing /program see "what SPD works on
// continuously", visitors browsing /event see "what's coming up on a
// calendar". Admin manages each in its own dashboard page.
model Program {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String   @default("")
  image       String?
  // Optional external link when the program lives on another site.
  link        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  // Human-readable date string shown to visitors (e.g. "20 November 2024").
  date        String    @default("")
  // Machine-readable start timestamp for chronological sort / "upcoming"
  // filters. Nullable so legacy rows without a parseable date still work.
  startsAt    DateTime?
  location    String    @default("")
  description String    @default("")
  image       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
  @@index([startsAt])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  status    String   @default("unread")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Log {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  userId    String?
  userName  String   @default("")
  details   String   @default("")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model Setting {
  id             Int      @id @default(1)
  siteName       String   @default("SPD Indonesia")
  email          String   @default("kontak@spdindonesia.org")
  logoUrl        String   @default("")
  heroUrl        String   @default("")
  placeholderUrl String   @default("")
  // Institutional text fields (long-form, editable from Settings page).
  visionText     String   @default("")
  // Short "Siapa Kami" intro that tops the About section.
  aboutIntro     String   @default("")
  // Positioning sentence under the site name on /beranda Hero and /entry.
  heroSubtitle   String   @default("")
  // Hero CTA buttons (two slots). Empty label = use default from i18n.
  heroCta1Label  String   @default("")
  heroCta1Href   String   @default("")
  heroCta2Label  String   @default("")
  heroCta2Href   String   @default("")
  // Footer social URLs. Empty = hide the icon.
  socialFacebook String   @default("")
  socialTwitter  String   @default("")
  socialLinkedin String   @default("")
  socialInstagram String  @default("")
  updatedAt      DateTime @updatedAt @default(now())
}

model Category {
  id        String   @id @default(cuid())
  value     String   @unique
  color     String   @default("text-slate-500")
  bg        String   @default("bg-slate-100")
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([sortOrder])
}

model Media {
  id        String   @id @default(cuid())
  // Optional semantic key, e.g. "homepage.hero", "footer.logo".
  // Unique so a key maps to exactly one asset at any time.
  key       String?  @unique
  url       String
  type      String   @default("")
  filename  String   @default("")
  size      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Partner {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String?
  websiteUrl String?
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}

model Stat {
  id        String   @id @default(cuid())
  value     String   // string so "9" and "100+" both work
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model TeamMember {
  id         String   @id @default(cuid())
  name       String
  role       String
  expertise  String   @default("")
  bio        String   @default("")
  photoUrl   String?
  featured   Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sortOrder])
}

model Milestone {
  id          String   @id @default(cuid())
  // Free-form year so ranges like "2016-2017" work. Sorted by sortOrder.
  year        String
  tag         String   @default("TONGGAK")
  title       String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model CoreValue {
  id          String   @id @default(cuid())
  // Same icon registry vocabulary as Approach — shared dropdown reduces
  // cognitive load for admins.
  iconKey     String   @default("collaboration")
  title       String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model Approach {
  id          String   @id @default(cuid())
  // iconKey picks from a fixed set defined in the frontend icon registry
  // (collaboration / data / youth / ...). Keeps icons SVG-in-code while
  // letting admin edit title + description freely.
  iconKey     String   @default("collaboration")
  title       String
  description String   @default("")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder])
}

model FooterLink {
  id        String   @id @default(cuid())
  // section: "nav" (kolom Navigasi) atau "layanan" (kolom Layanan).
  // Rendered in the footer column matching the section key.
  section   String
  label     String
  url       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([section, sortOrder])
}

model MissionItem {
  id        String   @id @default(cuid())
  text      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sortOrder])
}

model AnnualReport {
  id        String   @id @default(cuid())
  year      Int      @unique
  title     String
  summary   String   @default("")
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([year])
}

model Subscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  status         String    @default("active") // active | unsubscribed
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([createdAt])
}
